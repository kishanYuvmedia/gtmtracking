{
  "name": "gtmtracking-backend",
  "version": "1.0.0",
  "description": "GTM Tracking - Server Side Tracking & Conversion API Platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/database/migrate.ts",
    "worker": "tsx src/workers/eventWorker.ts",
    "meta-worker": "tsx src/workers/metaWorker.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
